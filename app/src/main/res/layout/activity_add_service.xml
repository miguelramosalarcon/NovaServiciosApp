<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Toolbar superior -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:title="Registrar Servicio"
        app:navigationIcon="@drawable/ic_arrow_back_24"
        app:titleCentered="true"/>

    <!-- Contenido del formulario -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Nombre -->
            <EditText
                android:id="@+id/etNombre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nombre del servicio"
                android:minHeight="48dp"
                android:layout_marginBottom="12dp"
                android:inputType="textCapCharacters"/>

            <!-- Tipo -->
            <EditText
                android:id="@+id/etTipo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Tipo de servicio"
                android:minHeight="48dp"
                android:layout_marginBottom="12dp"
                android:inputType="textCapCharacters"/>

            <!-- Fecha -->
            <EditText
                android:id="@+id/etFecha"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Seleccionar fecha"
                android:focusable="false"
                android:clickable="true"
                android:minHeight="48dp"
                android:layout_marginBottom="12dp"/>

            <!-- Hora -->
            <EditText
                android:id="@+id/etHora"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Seleccionar hora"
                android:focusable="false"
                android:clickable="true"
                android:minHeight="48dp"
                android:layout_marginBottom="12dp"/>

            <!-- Costo -->
            <EditText
                android:id="@+id/etCosto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Costo"
                android:inputType="numberDecimal"
                android:minHeight="48dp"
                android:layout_marginBottom="20dp"/>

            <!-- Botón Guardar -->
            <Button
                android:id="@+id/btnGuardar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Guardar Servicio"/>

            <!-- Botón ver servicios -->
            <Button
                android:id="@+id/btnVerServicios"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ver Servicios"
                android:backgroundTint="@color/nova_success_dark"
                android:layout_marginTop="12dp"/>

        </LinearLayout>

    </ScrollView>

</LinearLayout>