<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/space_16"
    app:cardCornerRadius="@dimen/card_radius"
    app:cardElevation="@dimen/card_elevation"
    app:strokeWidth="1dp"
    app:strokeColor="@color/nova_primary_light"
    app:cardBackgroundColor="@color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/space_16">

        <!-- Acento lateral -->
        <View
            android:id="@+id/viewAccent"
            android:layout_width="6dp"
            android:layout_height="0dp"
            android:background="@color/nova_primary"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Nombre -->
        <TextView
            android:id="@+id/tvNombre"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_16"
            android:text="SERVICIO 7"
            android:textColor="@color/nova_text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/viewAccent"
            app:layout_constraintEnd_toStartOf="@id/tvCosto"/>

        <!-- Costo (derecha) -->
        <TextView
            android:id="@+id/tvCosto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="S/ 777.00"
            android:textColor="@color/nova_success_dark"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="@id/tvNombre"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Tipo estilo chip -->
        <TextView
            android:id="@+id/tvTipo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_16"
            android:layout_marginTop="@dimen/space_8"
            android:paddingStart="@dimen/space_8"
            android:paddingEnd="@dimen/space_8"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:text="TIPO 7"
            android:textColor="@color/nova_primary"
            android:textSize="13sp"
            android:background="@drawable/bg_chip_tipo"
            app:layout_constraintTop_toBottomOf="@id/tvNombre"
            app:layout_constraintStart_toEndOf="@id/viewAccent"/>

        <!-- Fecha / Hora (línea ligera) -->
        <TextView
            android:id="@+id/tvFechaHora"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_16"
            android:layout_marginTop="@dimen/space_8"
            android:text="25 Feb 2026 • 03:50"
            android:textColor="@color/nova_text_secondary"
            android:textSize="14sp"
            android:letterSpacing="0.02"
            app:layout_constraintTop_toBottomOf="@id/tvTipo"
            app:layout_constraintStart_toEndOf="@id/viewAccent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>